{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "clipboard-manager:default",
    "global-shortcut:default",
    "notification:default",
    "store:default"
  ]
}
