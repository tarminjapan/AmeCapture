<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:viewmodel="clr-namespace:AmeCapture.App.ViewModels"
             x:Class="AmeCapture.App.Views.EditorPage"
             x:DataType="viewmodel:EditorViewModel"
             Title="Editor">

    <Grid RowDefinitions="Auto,*">
        <HorizontalStackLayout Grid.Row="0" Padding="8,4" Spacing="8">
            <Button Text="Select" Command="{Binding SetToolCommand}" CommandParameter="Select" />
            <Button Text="Arrow" Command="{Binding SetToolCommand}" CommandParameter="Arrow" />
            <Button Text="Rect" Command="{Binding SetToolCommand}" CommandParameter="Rectangle" />
            <Button Text="Mosaic" Command="{Binding SetToolCommand}" CommandParameter="Mosaic" />
            <Button Text="Text" Command="{Binding SetToolCommand}" CommandParameter="Text" />
            <Button Text="Crop" Command="{Binding SetToolCommand}" CommandParameter="Crop" />
            <BoxView WidthRequest="1" Color="Gray" Margin="4,0" />
            <Button Text="Undo" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" />
            <Button Text="Redo" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" />
            <BoxView WidthRequest="1" Color="Gray" Margin="4,0" />
            <Button Text="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}" />
            <Button Text="Save As" Command="{Binding SaveAsCommand}" />
            <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}" WidthRequest="24" HeightRequest="24" />
        </HorizontalStackLayout>

        <skia:SKCanvasView x:Name="CanvasView"
                           Grid.Row="1"
                           PaintSurface="OnPaintSurface"
                           EnableTouchEvents="True"
                           Touch="OnTouch" />
    </Grid>

</ContentPage>
